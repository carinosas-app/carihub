{
  "version": "0.2.0",
  "mode": "report-only",
  "repoRootEnv": "CARIHUB_REPO_ROOT",
  "reportsDir": "agent-tools/camcp-reports",
  "denyWritePaths": [
    "public/",
    "firestore.rules",
    "firestore.indexes.json",
    "storage.rules",
    "firebase.json",
    ".firebaserc",
    "functions/"
  ],
  "denyReadPatterns": [],
  "gitAllowedSubcommands": [
    "status",
    "log",
    "diff",
    "branch",
    "rev-parse",
    "merge-base",
    "show",
    "worktree",
    "rev-list"
  ],
  "filesystemMaxReadBytes": 524288,
  "filesystemMaxSearchResults": 500,
  "filesystemMaxTreeDepth": 8,
  "filesystemMaxListEntries": 1000
}
