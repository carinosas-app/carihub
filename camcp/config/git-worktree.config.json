{
  "version": "1.0.0",
  "schemaVersion": "1.0.0",
  "ghEnabled": true,
  "defaults": {
    "baseRef": "main",
    "remoteRef": "origin/main",
    "headRef": "HEAD",
    "includeUntracked": true,
    "diffStatOnly": true,
    "maxChangedFiles": 500
  },
  "stale": {
    "maxBehindCommits": 50,
    "maxIdleDays": 14
  },
  "diff": {
    "largeChangeThreshold": 50,
    "archReviewFileThreshold": 10
  },
  "conflicts": {
    "compareWorktrees": true,
    "compareBranches": true,
    "behindDirtyThreshold": 10
  },
  "cleanup": {
    "reportOnly": true,
    "includeDetached": true,
    "includeMergedBranches": true
  },
  "pr": {
    "enabled": true,
    "inferFromBranch": true
  }
}
