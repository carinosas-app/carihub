  "impactQaHints": {
    "APP_REGISTRO": ["paridad_static", "paridad_vm", "paridad_render_strict", "parity.static", "parity.vm", "parity.render_strict", "data.pipeline_status", "data.persist_audit", "data.hydrate_audit", "data.schema_alignment"],
    "APP_PUBLICA": ["fondos_static", "paridad_render_strict", "parity.render_strict"],
    "APP_BANNERS": ["fondos_static"],
    "default": ["fondos_static"]
