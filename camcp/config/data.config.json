{
  "version": "0.1.0",
  "tools": {
    "data.pipeline_status": {
      "qaTool": "qa.run_paridad_vm",
      "reuses": ["qaRunParidadVm", "runQaScript", "scripts/qa-paridad-reg-pub-vm.mjs", "reports/aggregator"],
      "artifactFiles": ["pipeline-summary.json", "failures.json", "pipeline-detail.json"]
    },
    "data.persist_audit": {
      "qaTool": "qa.run_p0_persist_privacy",
      "reuses": ["qaRunP0PersistPrivacy", "runQaScript", "scripts/qa-p0-reg-persist-privacy.mjs", "reports/aggregator"],
      "artifactFiles": ["stdout.txt", "stderr.txt"]
    },
    "data.hydrate_audit": {
      "qaTool": "qa.run_submit_hydrate",
      "reuses": ["qaRunSubmitHydrate", "runQaScript", "scripts/qa-mp-submit-hydrate.mjs", "reports/aggregator"],
      "artifactFiles": ["stdout.txt", "stderr.txt"]
    },
    "data.schema_alignment": {
      "qaTool": "qa.run_validar_schemas",
      "reuses": ["qaRunValidarSchemas", "runQaScript", "scripts/validar-schemas-registro.mjs", "scripts/validacion-schemas-report.json"],
      "artifactFiles": ["stdout.txt", "stderr.txt"]
    }
  }
}
