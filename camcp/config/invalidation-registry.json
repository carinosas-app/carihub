        {
          "watchId": "ssot.registro-schema-index",
          "kind": "ssot",
          "ssotId": "registro-schema-index",
          "invalidates": ["*"],
          "completedCheckPattern": "catalog.audit:*"
        }
      ]
    },
    {
      "facadeId": "profile.audit",
      "registrations": [
