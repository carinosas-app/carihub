          "completedCheckPattern": "profile.audit:{registration,private_fields,full}"
        },
        {
          "watchId": "git.head",
          "kind": "git",
          "source": "git.head",
          "invalidates": ["*"],
          "completedCheckPattern": "profile.audit:*|arch.review:*|git.worktree:*"
        },
        {
          "watchId": "git.branch",
          "kind": "git",
          "source": "git.branch",
          "invalidates": ["*"],
          "completedCheckPattern": "profile.audit:*|arch.review:*|git.worktree:*"
        }
      ]
    },
    {
      "facadeId": "arch.review",
