          "kind": "ssot",
          "ssotId": "arch-config",
          "invalidates": ["frozen", "duplicates", "full"],
          "completedCheckPattern": "arch.review:{frozen,duplicates,full}"
        },
        {
          "watchId": "glob.acta-congelamiento",
          "kind": "glob",
          "pathGlob": "scripts/ACTA-CONGELAMIENTO-*.json",
