      "limitesRef": "SPEC-MESSENGER-ALCANCE → usuarioNuevo.conversacionesNuevasDia: 5",
      "accionSistema": ["bloquear_nuevas_conversaciones", "cola_admin", "incrementar_riesgoScore"],
