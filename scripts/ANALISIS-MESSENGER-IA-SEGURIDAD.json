  "objetivoCapa": "Pipeline de análisis de riesgo en tiempo de envío/recepción de mensajes que combina reglas determinísticas, heurísticas, listas y señales IA — sin sustituir moderación humana ni gates congelados",
  "pipelineAnalisisMensaje": {
    "orden": [
      "1. validateAction — ValidationEngine (auth, rate limits, estadoMensajeria, estadoSeguridad, bloqueos)",
      "2. reglasDeterministicas — palabras prohibidas, URLs, patrones masivos",
      "3. heuristicaSpam — duplicados, burst, spamScore acumulado",
      "4. analisisEnlaces — dominio, reputación, phishing conocido",
      "5. senalesIA — ia_seguridad_messenger + ia_moderacion_messenger (async o pre-envío según severidad)",
      "6. decisionSistema — permitir | retrasar | cola_revision | rechazar | elevar_admin",
      "7. emitEventoCanonico — fanOutPlan según resultado",
      "8. auditoria — logsSeguridad, ia_recomendaciones, logsAdmin"
    ],
    "principio": "Reglas sistema tienen prioridad sobre IA; IA nunca ejecuta bloqueo permanente sin cola admin"
  },
