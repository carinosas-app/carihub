  "resolucionConflictos": {
    "conflictosResueltos": [
      {
        "id": "C-R01",
        "conflicto": "/cuenta/banners vs /cuenta/anunciante",
        "veredicto": "CANON: /cuenta/banners",
        "aliases": [
          { "ruta": "/cuenta/anunciante", "accion": "redirect_301", "destino": "/cuenta/banners" },
          { "ruta": "/cuenta/anunciante/*", "accion": "redirect_301", "destino": "/cuenta/banners/*" }
        ],
        "justificacion": "Alineado SPEC-PANEL, contratos_banners PAY, dashboard_banners ACTA-DASH"
      },
      {
        "id": "C-R02",
        "conflicto": "/registro/editar/{perfilId} vs /cuenta/perfil/editar",
        "veredicto": "CANON: /registro/editar/{perfilId}",
        "aliases": [
          { "ruta": "/cuenta/perfil/editar", "accion": "redirect_302", "destino": "/registro/editar/{perfilId}" },
          { "ruta": "/cuenta/perfil/editar/*", "accion": "redirect_302", "destino": "/registro/editar/{perfilId}" }
        ],
        "justificacion": "ACTA-RC: Registro edita wizard FieldEngine; Dashboard solo CTA"
      },
      {
        "id": "C-R03",
        "conflicto": "/admin/expedientes/* vs /admin/revision vs /admin/perfiles",
        "veredicto": "CANON: rutas PLAN-MAESTRO-ADMIN planas; expedientes = agrupación UI menú no URL",
        "mapeo": [
          { "legacy": "/admin/expedientes/perfiles", "canon": "/admin/revision?tipo=perfil", "alternativa": "/admin/perfiles?estado=pendiente" },
          { "legacy": "/admin/expedientes/anunciantes", "canon": "/admin/revision?tipo=banner", "alternativa": "/admin/banners?estado=pendiente" },
          { "legacy": "/admin/expedientes/pagos", "canon": "/admin/pagos?estado=pendiente" },
          { "legacy": "/admin/expedientes/contratos", "canon": "/admin/contratos" }
        ],
        "justificacion": "PLAN-ADMIN 16 rutas operativas; SPEC-PANEL expedientes = taxonomía menú"
      },
      {
        "id": "C-R04",
        "conflicto": "admin.html vs /admin/*",
        "veredicto": "CANON futuro: /admin/* modular; LEGACY MVP: admin.html bridge",
        "bridge": {
          "archivoLegacy": "public/admin.html",
          "entradaCanon": "/admin/resumen",
          "estrategia": "MVP admin.html sirve rutas /admin/* vía hash o rewrite; Post-MVP router SPA",
          "redirect": { "desde": "/admin.html", "hacia": "/admin/resumen", "fase": "runtime" }
        }
      },
      {
        "id": "C-R05",
        "conflicto": "index.html modales vs navegación modular /cuenta/*",
        "veredicto": "CANON futuro: /cuenta/* shell; LEGACY MVP: modales index.html bridge",
        "bridge": {
          "archivoLegacy": "public/index.html",
          "mapeoModales": [
            { "modal": "modalMiPerfil", "canon": "/cuenta/acceso", "accion": "login" },
            { "modal": "modalPanel", "canon": "/cuenta/perfil", "accion": "panel cuenta" },
            { "modal": "modalEditar", "canon": "/registro/editar/{perfilId}", "accion": "edición" },
            { "modal": "modal-registro", "canon": "/registro/wizard", "accion": "onboarding" }
          ],
          "estrategia": "Desacople APP-PUBLICA: Home permanece /; cuenta migra a /cuenta y /registro"
        }
      },
      {
        "id": "C-R06",
        "conflicto": "registro-banner.html vs /cuenta/banners/solicitud",
        "veredicto": "CANON onboarding: /registro/banner; CANON panel: /cuenta/banners",
        "aliases": [
          { "ruta": "public/registro-banner.html", "accion": "legacy_bridge", "destino": "/registro/banner", "fase": "runtime" }
        ]
      }
    ],
    "conflictosPendientes": [
      { "id": "C-P01", "tema": "/cuenta/negocio vs /cuenta/perfil variante negocio", "estado": "pendiente_MINOR_1.1", "nota": "MVP: /cuenta/perfil con tipoPerfil=negocio" },
      { "id": "C-P02", "tema": "/operador vs /admin scope reducido", "estado": "pendiente_SPEC-ADMIN", "nota": "Operador staff RBAC Post-MVP" },
      { "id": "C-P03", "tema": "/messenger vs WhatsApp externo MVP", "estado": "resuelto_MVP_externo", "canonMvp": "WhatsApp perfil público; /messenger Post-MVP V1.1" }
    ]
  },

