  "seccion5_matrizPrivacidad": {
    "clases": ["publico", "privado", "sensible", "financiero", "administrativo", "auditoria"],
    "filas": [
      { "entidad": "perfil público (nombre, fotos, categoría, ciudad, contacto)", "clase": "publico", "exposicion": "indexable /perfil/{id}/{slug}", "regla": "isPublicProfile()" },
      { "entidad": "favoritos, notificaciones, config usuario", "clase": "privado", "exposicion": "solo owner", "regla": "isOwner" },
      { "entidad": "INE, selfie, edad, verificaciones, telefonoE164", "clase": "sensible", "exposicion": "owner + admin con log_acceso_privado", "regla": "owner|admin + auditoría obligatoria; Storage rules" },
      { "entidad": "pagos, contratos, RFC, comprobantes, montos", "clase": "financiero", "exposicion": "owner(read) + admin + sistema", "regla": "nunca público; PrivacyGuard PAY" },
      { "entidad": "estadoSeguridad, riesgoScore, flags, observacionesAdmin", "clase": "administrativo", "exposicion": "admin/moderador; no owner directo", "regla": "no en widgets usuario" },
      { "entidad": "logsAdmin, logsSeguridad, logs_acceso_privado, alertas", "clase": "auditoria", "exposicion": "admin/auditor; append-only", "regla": "no update/delete; PII solo hash" }
    ],
    "reglaTransversal": "RFC completo, comprobante Storage URL, datos fiscales raw, contenido mensajes P2P sin auditoría = nunca_panel / nunca_público (SPEC matrizPrivacidad)"
  },

  "seccion6_matrizRBAC": {
    "modeloActual": { "roles": ["owner", "admin(email único)"], "mecanismo": "request.auth.uid + request.auth.token.email", "limitacion": "Sin moderador/soporte/auditor/sistema; single point admin" },
    "modeloCanonico": { "mecanismo": "Firebase custom claims (role + scope)", "roles": ["visitante", "usuario", "prestador", "negocio", "anunciante", "super_admin", "admin", "moderador", "soporte", "auditor", "comercial_admin", "operador", "agente_ia(escritura=false)", "sistema"] },
    "permisosHeredados": [
      "super_admin ⊇ admin ⊇ moderador (moderación) ",
      "admin ⊇ comercial_admin (pagos/contratos)",
      "prestador ⊇ usuario (favoritos/config)",
      "negocio ≈ prestador (tipoPerfil=negocio)"
    ],
    "permisosExclusivos": [
      "super_admin: cambio_RBAC, asignar_claims",
      "comercial_admin: confirmar_pago, conciliación",
      "auditor: export logs, read sensible con log",
      "moderador: suspender_perfil, resolver_denuncia",
      "agente_ia: solo lectura + recomendación (escritura=false)"
    ],
    "permisosCriticos": ["asignar_claims", "confirmar_pago", "suspender_perfil", "delete usuarios", "leer_verificaciones", "export_datos"],
    "escalacionProhibida": [
      "usuario→admin vía update propio (bloqueado: campos rol/claims no editables por owner)",
      "anunciante→prestador sin perfil verificado",
      "moderador→super_admin (sin asignar_claims)",
      "agente_ia→escritura (escritura=false absoluto)",
      "owner no puede modificar estadoPago/verificacion/vencido (usuarioUpdateDuenoValido bloquea)"
    ]
  },

