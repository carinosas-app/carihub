    "scripts/config-registro-schema.meta.json"
  ],
  "principios": [
    "FieldEngine resuelve schema; ValidationEngine valida valores y autoriza acción",
    "Turnstile y rate limits solo en ValidationEngine — nunca solo cliente",
    "Gates estado: FieldEngine evaluateSecurityGates + reglas ValidationEngine dashboard",
    "Toda acción exitosa construye fanOutPlan desde registry-validationengine-eventos.json",
    "IA nunca persiste sin validateIAConfirmation",
    "No escribe catálogo ni precios; admin humano confirma acciones IA"
  ],
  "api": {
    "validateAction": {
      "entrada": "ValidationContext",
      "salida": "ValidationResult | ValidationError",
      "descripcion": "Pipeline principal — ver algoritmoValidacion"
    },
    "verifyTurnstile": {
      "entrada": "{ token, action, remoteIp? }",
      "salida": "TurnstileResult",
      "implementacion": "Cloud Function server-side — diseño"
    },
    "checkRateLimits": {
      "entrada": "{ accion, dimensiones: RateLimitBucket[] }",
      "salida": "RateLimitResult"
    },
    "validateFieldValues": {
      "entrada": "{ schema: ResolvedRegistrationSchema, values: Record<string, unknown> }",
      "salida": "FieldValidationResult"
    },
    "validateStates": {
      "entrada": "{ cuenta, seguridad, mensajeria?, perfil?, accion }",
      "salida": "StateValidationResult"
    },
    "validateFormulario": {
      "entrada": "{ modo, formularioId, flujoVisitante?, subcategoriaId? }",
      "salida": "FormularioValidationResult",
      "nota": "Pre-check antes de resolve FieldEngine"
    },
    "evaluateDashboardAction": {
      "entrada": "{ dashboardContext, accion, usuarioId, roles, entidad? }",
      "salida": "DashboardAuthResult"
    },
    "emitEventoCanonico": {
      "entrada": "EventoCanonico",
      "salida": "EventBusResult",
      "efecto": "Fan-out notificaciones + historial_actividad — diseño persistencia futura"
    },
    "validateIARecommendation": {
      "entrada": "{ recomendacionId, confirmacionHumana, actorId }",
      "salida": "IAValidationResult"
    },
    "validateMedia": {
      "entrada": "MediaValidationContext",
      "salida": "MediaValidationResult | ValidationError",
      "descripcion": "Validar upload antes de Storage write — MIME, tamaño, extensión, path, peligrosos"
    },
    "validateAuth": {
      "entrada": "{ idToken, accion, emailVerificadoRequerido? }",
      "salida": "AuthValidationResult",
      "descripcion": "Verificar Firebase Auth token server-side; mirror emailVerificado"
    }
  },
  "tipos": {
    "ValidationContext": {
      "accion": "ValidationAction",
      "usuarioId": "string",
      "turnstileToken": "string|null",
      "ipHash": "string",
      "deviceIdHash": "string|null",
      "fieldEngineContext": "FieldEngineContext|null",
      "values": "Record<string, unknown>|null",
      "resolvedSchema": "ResolvedRegistrationSchema|null — pre-resuelto o interno",
      "cuenta": "CuentaContext",
      "seguridad": "SecurityContext",
      "mensajeria": "MensajeriaContext|null",
      "perfil": "PerfilContext|null",
      "dashboardContext": "admin|shell_cuenta|shell_perfil|shell_banners|null",
      "metadata": "Record<string, unknown>"
    },
    "ValidationResult": {
      "ok": true,
      "accion": "string",
      "validationId": "uuid",
      "gates": "SecurityGateResult[]",
      "fieldErrors": "FieldError[]",
      "fanOutPlan": "FanOutPlanItem[] — ver registry y contratoMultiDestino",
      "eventoCanonico": "EventoCanonico|null — legacy; preferir fanOutPlan",
      "persistenciaAutorizada": "boolean — diseño; ejecutor futuro",
      "meta": { "validatedAt": "ISO8601", "schemaVersion": "string" }
    },
    "ValidationError": {
      "ok": false,
      "codigo": "string",
      "http": "number",
      "motivo": "string",
      "detalles": "unknown",
      "retry": "boolean"
    }
  },
  "acciones": {
    "auth": ["login", "registro_auth", "recuperacion_password", "reenvio_email_verificacion"],
    "perfil": ["guardar_borrador", "enviar_revision", "editar_perfil", "actualizar_perfil_publicado", "renovar_contrato", "subir_foto_perfil", "subir_video_perfil", "subir_verificacion_ine_frente", "subir_verificacion_ine_reverso", "subir_selfie_verificacion", "solicitar_verificacion"],
    "visitante": ["registro_visitante", "upgrade_perfil_publico", "guardar_preferencias"],
    "banner": ["crear_solicitud_banner", "editar_banner", "actualizar_solicitud_pre_pago", "enviar_correccion_banner", "subir_banner_imagen", "subir_banner_video"],
    "catalogo": ["categoria_sugerida"],
    "social": ["denuncia", "contacto_publico", "favorito_add", "favorito_remove"],
    "mensajeria": [
      "mensaje_enviar",
      "conversacion_iniciar_directa",
      "conversacion_iniciar_solicitud",
      "solicitud_conversacion_aceptar",
      "solicitud_conversacion_rechazar",
      "bloqueo_usuario",
      "bloqueo_usuario_remover",
      "reportar_conversacion",
      "reportar_mensaje",
      "reportar_usuario_mensajeria",
      "mensaje_eliminar_para_todos",
      "conversacion_archivar",
      "conversacion_silenciar",
      "conversacion_fijar",
      "conversacion_ocultar",
      "automatizacion_enviar",
      "automatizacion_activar",
      "automatizacion_desactivar",
      "admin_automatizaciones_suspendir",
      "admin_messenger_suspender",
      "admin_messenger_suspension_levantar",
      "admin_messenger_deshabilitar_ambito",
      "admin_messenger_habilitar_ambito",
      "admin_conversacion_cerrar"
    ],
    "ia": ["ia_consulta", "ia_aceptar_recomendacion", "ia_rechazar_recomendacion"],
    "admin": ["admin_aprobar_perfil", "admin_rechazar_perfil", "admin_cambio_estado_seguridad", "admin_actualizar_solicitud_banner"],
    "routingAcciones": {
      "conversacion_iniciar": {
        "metadata": "modoInicio",
        "directa": "conversacion_iniciar_directa",
        "solicitud": "conversacion_iniciar_solicitud",
        "nota": "Acción cliente Messenger; normalizar antes de fanOutPlan paso 12"
      }
    },
    "nota": "VE 1.1.0 MINOR Messenger — 24 acciones registry; routing conversacion_iniciar"
  },
  "gatesMensajeriaValidateStates": {
    "pasoPipeline": 6,
    "actaMinor": "scripts/ACTA-MINOR-VALIDATIONENGINE-1.1.0-MESSENGER.json",
    "ordenEvaluacion": ["messengerHabilitadoAmbito", "estadoMensajeria", "estadoSeguridad", "telefonoVerificado", "spamScore"],
    "messengerHabilitadoAmbito": {
      "campo": "messengerHabilitadoAmbito",
      "denegarSi": false,
      "error": "MESSENGER_DESHABILITADO_AMBITO",
      "excepciones": ["admin_messenger_habilitar_ambito", "admin_messenger_deshabilitar_ambito"]
    },
    "telefonoVerificado": {
      "campo": "usuarios.seguridad.telefonoVerificado",
      "requerido": true,
      "acciones": ["mensaje_enviar", "conversacion_iniciar_directa", "conversacion_iniciar_solicitud"],
      "error": "TELEFONO_NO_VERIFICADO"
    },
    "spamScore": {
      "campo": "usuarios.mensajeria.spamScore",
      "umbral": 60,
      "denegarSi": "spamScore >= 60",
      "error": "SPAM_SCORE_UMBRAL",
      "acciones": ["mensaje_enviar", "conversacion_iniciar_directa", "conversacion_iniciar_solicitud", "automatizacion_enviar"],
      "nota": "validateAction no muta spamScore"
    },
    "estadoMensajeriaRestringida": {
      "regla": "estadoMensajeria restringida: solo mensaje_enviar en conversaciones activa|reportada — no conversacion_iniciar directa",
      "fuente": "SPEC-MESSENGER.json integracionValidationEngine.gatesMessengerValidateStates"
    }
  },
  "algoritmoValidacion": {
    "orden": [
      "1. validateFormulario — modo y contexto coherente",
      "2. evaluateDashboardAction — permisos shell/admin si aplica",
      "3. validateAuth — idToken Firebase si acción autenticada (ver reglasAuthTurnstile)",
      "4. verifyTurnstile — si acción anónima/pública lo requiere (config-seguridad-mvp)",
      "5. checkRateLimits — dimensiones ip/usuario/email/dispositivo/perfil",
      "6. validateStates — estadoCuenta, estadoVerificacion, estadoSeguridad, estadoMensajeria, estadoPublicacion, estadoRevision",
      "7. FieldEngine.resolveRegistrationSchema — si accion perfil/visitante y schema no provisto",
      "8. evaluateSecurityGates — delegar reglas FieldEngine 1.0.1",
      "9. validateFieldValues — tipos, obligatorios, coherencia, fotos min/max",
      "10. validateMedia — si acción incluye upload",
      "11. Reglas específicas acción (banner, denuncia, IA, renovar)",
      "12. Construir fanOutPlan desde registry-validationengine-eventos.json[accion]",
      "13. emitEventoCanonico — ejecutar cada ítem fanOutPlan (multi-destino)",
      "14. Retornar ValidationResult con fanOutPlan y validationId"
    ],
    "falloTemprano": "Cualquier paso falla → ValidationError sin emitir evento ni fanOutPlan",
    "reglasAuthTurnstile": {
      "descripcion": "OB-VE1 — Auth antes de Turnstile en acciones autenticadas",
      "accionesSoloAnonimasSinAuth": ["login", "registro_auth", "registro_visitante", "recuperacion_password", "denuncia", "contacto_publico", "categoria_sugerida"],
      "accionesAutenticadasRequierenAuth": "Todas las demás en acciones.* incluyendo guardar_borrador, enviar_revision, admin_*, subir_*",
      "turnstileEnAutenticadas": "crear_solicitud_banner — Turnstile además de Auth si política anti-bot banner",
      "ordenExcepcion": "registro_auth y registro_visitante: Turnstile paso 4 sin Auth previo; validateAuth aplica post-creación cuenta en persistencia futura"
    }
  },
  "turnstile": {
    "proveedor": "cloudflare_turnstile",
    "referencia": "config-seguridad-mvp-schema.json → antiBots.decision",
    "verificacion": "server-side Cloud Function — secret no en cliente",
    "accionesRequierenTurnstile": {
      "login": true,
      "registro_auth": true,
      "recuperacion_password": true,
      "reenvio_email_verificacion": true,
      "registro_visitante": true,
      "enviar_revision": false,
      "guardar_borrador": false,
      "crear_solicitud_banner": true,
      "categoria_sugerida": true,
      "denuncia": true,
      "contacto_publico": true,
      "nota": "enviar_revision: usuario autenticado; gates por estado + rate limit edición"
    },
    "errores": ["TURNSTILE_TOKEN_FALTANTE", "TURNSTILE_VERIFICACION_FALLIDA", "TURNSTILE_ACTION_MISMATCH"]
  },
  "rateLimits": {
    "referencia": "config-seguridad-mvp-schema.json → antiSpam.limitesPorAccion",
    "almacenamiento": "rate_limits/{bucketId} — diseño Firestore TTL",
    "dimensiones": ["ip", "usuario", "email", "dispositivo", "perfil", "perfilObjetivo"],
    "accionesMapeadas": {
      "registro_auth": "registro_cuenta",
      "login": "login_fallido",
      "recuperacion_password": "recuperacion_password",
      "denuncia": "denuncia",
      "categoria_sugerida": "categoria_sugerida",
      "mensaje_enviar": "mensaje_futuro",
      "enviar_revision": "publicacion_edicion",
      "guardar_borrador": "publicacion_edicion",
      "ia_consulta": { "ventana": "1h", "max": 30, "usuario": true }
    },
    "errores": ["RATE_LIMIT_EXCEDIDO"],
    "log": "logsSeguridad tipo rate_limit"
  },
  "validacionCampos": {
    "entradaSchema": "ResolvedRegistrationSchema de FieldEngine",
    "reglas": [
      "obligatorios presentes incluyendo anidados geo.ciudad",
      "tipos fieldRegistry: email, text, number, boolean, geo, file, checklist",
      "coherencia[] — evaluar si/entonces del schema",
      "fotos: count entre min y max",
      "camposPrivados no en payload público resultados",
      "sanitización HTML en textos públicos",
      "longitudes maxLength del registry"
    ],
    "errores": ["CAMPO_OBLIGATORIO_FALTANTE", "TIPO_INVALIDO", "COHERENCIA_VIOLADA", "FOTOS_MIN_NO_ALCANZADO", "FOTOS_MAX_EXCEDIDO"]
  },
    "validacionEstados": {
      "erroresCatalogados": ["ESTADO_CUENTA_INVALIDO", "ESTADO_SEGURIDAD_DENEGADO", "ESTADO_MENSAJERIA_DENEGADO", "EMAIL_NO_VERIFICADO"],
      "campos": {
      "estadoCuenta": ["activa", "suspendida", "eliminada", "pendiente_activacion"],
      "estadoVerificacion": ["sin_enviar", "enviada", "en_revision", "aprobada", "rechazada", "vencida"],
      "estadoSeguridad": ["normal", "observacion", "restringido", "suspendido", "bloqueado"],
      "estadoMensajeria": ["habilitada", "restringida", "suspendida", "solo_lectura"],
      "estadoPublicacion": ["borrador", "publicado", "activo", "despublicado", "vencido"],
      "estadoRevision": ["registro_pendiente", "actualizacion_pendiente", "aprobada", "rechazada", "sin_estado"]
    },
    "matrizAccionEstado": {
      "guardar_borrador": { "estadoCuenta": ["activa"], "estadoSeguridad": ["normal", "observacion", "restringido"] },
      "enviar_revision": { "emailVerificado": true, "estadoSeguridad": ["normal", "observacion"], "estadoCuenta": ["activa"] },
      "mensaje_enviar": { "estadoMensajeria": ["habilitada"], "estadoSeguridad": ["normal", "observacion"] },
      "crear_solicitud_banner": { "emailVerificado": true, "estadoSeguridad": ["normal", "observacion"] }
    },
    "alineacionFieldEngine": "evaluateSecurityGates — no duplicar lógica; ValidationEngine invoca o comparte módulo",
    "errores": ["ESTADO_CUENTA_INVALIDO", "ESTADO_SEGURIDAD_DENEGADO", "ESTADO_MENSAJERIA_DENEGADO", "EMAIL_NO_VERIFICADO"]
  },
  "validacionFormularios": {
    "modos": {
      "default": { "requiereSubcategoriaId": true, "fieldEngineModo": "default" },
      "alternativo": { "requiereSubcategoriaId": true, "fieldEngineModo": "alternativo" },
      "temporal_categoria_sugerida": { "turnstile": true, "rateLimit": "categoria_sugerida", "fieldEngineModo": "temporal_categoria_sugerida" },
      "usuario_visitante": {
        "registro_inicial": { "subcategoriaId": false, "formularioId": "usuario_visitante" },
        "upgrade_perfil_publico": { "subcategoriaId": true, "contratoVigente": true }
      },
      "publicidad_banner": { "formularioId": null, "schema": "solicitudes_anuncios payload", "turnstile": true }
    },
    "errores": ["MODO_FORMULARIO_INVALIDO", "SUBCATEGORIA_REQUERIDA_UPGRADE_VISITANTE", "CONTRATO_NO_VIGENTE"]
  },
  "validacionAuth": {
    "proveedor": "firebase_auth",
    "verificacion": "server-side Admin SDK o Callable — diseño",
    "reglas": [
      "idToken presente y no expirado para acciones autenticadas",
      "usuarioId del token debe coincidir con ValidationContext.usuarioId",
      "emailVerificado mirror usuarios.seguridad.emailVerificado — gate enviar_revision, banner, upgrade",
      "cuenta deshabilitada Auth → ESTADO_CUENTA_INVALIDO",
      "admin fase1: email allowlist; fase2: custom claims RBAC"
    ],
    "errores": ["AUTH_TOKEN_FALTANTE", "AUTH_TOKEN_INVALIDO", "AUTH_USUARIO_MISMATCH", "EMAIL_NO_VERIFICADO"]
  },
  "validacionMedia": {
    "referencia": "config-seguridad-mvp-schema.json → storageRules diseño",
    "principios": [
      "Validar antes de cualquier write Storage",
      "Path debe coincidir con perfilId/bannerId del owner autenticado",
      "Rechazar ejecutables, scripts, doble extensión, MIME spoofing",
      "Magic bytes opcional post-MVP; MVP confía MIME declarado + extensión + size"
    ],
    "tipos": {
      "foto_perfil": {
        "mimePermitidos": ["image/jpeg", "image/png", "image/webp"],
        "extensiones": [".jpg", ".jpeg", ".png", ".webp"],
        "maxBytes": 5242880,
        "storagePathPattern": "^perfiles/\\{perfilId\\}/fotos/[a-zA-Z0-9_-]+\\.(jpg|jpeg|png|webp)$",
        "privado": false,
        "accion": "subir_foto_perfil"
      },
      "video_perfil": {
        "mimePermitidos": ["video/mp4", "video/webm"],
        "extensiones": [".mp4", ".webm"],
        "maxBytes": 52428800,
        "maxDuracionSegundos": 120,
        "storagePathPattern": "^perfiles/\\{perfilId\\}/videos/[a-zA-Z0-9_-]+\\.(mp4|webm)$",
        "privado": false,
        "accion": "subir_video_perfil"
      },
      "banner_imagen": {
        "mimePermitidos": ["image/jpeg", "image/png", "image/webp", "image/gif"],
        "extensiones": [".jpg", ".jpeg", ".png", ".webp", ".gif"],
        "maxBytes": 8388608,
        "storagePathPattern": "^solicitudes_anuncios/\\{solicitudId\\}/creativos/[a-zA-Z0-9_-]+\\.(jpg|jpeg|png|webp|gif)$",
        "accion": "subir_banner_imagen"
      },
      "banner_video": {
        "mimePermitidos": ["video/mp4", "video/webm"],
        "extensiones": [".mp4", ".webm"],
        "maxBytes": 104857600,
        "maxDuracionSegundos": 30,
        "storagePathPattern": "^solicitudes_anuncios/\\{solicitudId\\}/creativos/[a-zA-Z0-9_-]+\\.(mp4|webm)$",
        "accion": "subir_banner_video"
      },
      "ine_frente": {
        "mimePermitidos": ["image/jpeg", "image/png"],
        "extensiones": [".jpg", ".jpeg", ".png"],
        "maxBytes": 10485760,
        "storagePathPattern": "^perfiles/\\{perfilId\\}/verificacion/ine_frente/[a-zA-Z0-9_-]+\\.(jpg|jpeg|png)$",
        "privado": true,
        "soloOwnerYAdmin": true,
        "accion": "subir_verificacion_ine_frente"
      },
      "ine_reverso": {
        "mimePermitidos": ["image/jpeg", "image/png"],
        "extensiones": [".jpg", ".jpeg", ".png"],
        "maxBytes": 10485760,
        "storagePathPattern": "^perfiles/\\{perfilId\\}/verificacion/ine_reverso/[a-zA-Z0-9_-]+\\.(jpg|jpeg|png)$",
        "privado": true,
        "soloOwnerYAdmin": true,
        "accion": "subir_verificacion_ine_reverso"
      },
      "selfie_verificacion": {
        "mimePermitidos": ["image/jpeg", "image/png"],
        "extensiones": [".jpg", ".jpeg", ".png"],
        "maxBytes": 8388608,
        "storagePathPattern": "^perfiles/\\{perfilId\\}/verificacion/selfie/[a-zA-Z0-9_-]+\\.(jpg|jpeg|png)$",
        "privado": true,
        "soloOwnerYAdmin": true,
        "accion": "subir_selfie_verificacion"
      },
      "comprobante_pago": {
        "mimePermitidos": ["image/jpeg", "image/png", "application/pdf"],
        "extensiones": [".jpg", ".jpeg", ".png", ".pdf"],
        "maxBytes": 10485760,
        "storagePathPattern": "^(pagos|contratos_perfiles)/\\{entidadId\\}/comprobantes/[a-zA-Z0-9_-]+\\.(jpg|jpeg|png|pdf)$",
        "privado": true,
        "accion": "subir_comprobante"
      }
    },
    "rechazoArchivosPeligrosos": {
      "mimeBloqueados": ["application/x-msdownload", "application/javascript", "text/html", "application/x-sh", "application/x-php"],
      "extensionesBloqueadas": [".exe", ".bat", ".cmd", ".sh", ".php", ".js", ".html", ".svg"],
      "reglas": ["doble_extension", "path_traversal", "null_byte", "mime_extension_mismatch"],
      "errores": ["MEDIA_TIPO_NO_PERMITIDO", "MEDIA_TAMANO_EXCEDIDO", "STORAGE_PATH_INVALIDO", "MEDIA_ARCHIVO_PELIGROSO", "MEDIA_EXTENSION_NO_PERMITIDA"]
    },
    "futuroFueraAlcance": {
      "stories_media": "scripts/OBSERVACION-ARQUITECTONICA-INTERACCIONES.json v1.2.1",
      "live_stream_chunks": "SPEC Interacciones futura"
    }
  },
