{
  "$schema": "./config-registro-schema.meta.json",
  "versionSchema": "2026-06-10",
  "version": "2026-06-10",
  "schemaId": "seguridad_mvp",
  "nombre": "CariHub — Seguridad MVP (anti-bots, anti-spam, reputación)",
  "descripcion": "Diseño pre-implementación. Medidas mínimas obligatorias antes de lanzamiento público. No modifica Firestore ni producción hasta fase autorizada.",
  "estado": "CONGELADO",
  "fechaCongelamiento": "2026-06-09",
  "acta": "scripts/ACTA-CONGELAMIENTO-SEGURIDAD.json",
  "dependenciasCongeladas": {
    "catalogo": { "id": "catalogo-2026-06-10", "semver": "1.0.0", "acta": "ACTA-CONGELAMIENTO-CATALOGO.json" },
    "cuentas": { "id": "cuentas-2026-06-10", "semver": "1.0.0", "acta": "ACTA-CONGELAMIENTO-CUENTAS.json" }
  },
  "antiBots": {
    "recomendacionPrincipal": "cloudflare_turnstile",
    "alternativa": "google_recaptcha_v3",
    "comparativa": {
      "cloudflare_turnstile": {
        "ventajas": [
          "Gratis con verificaciones ilimitadas en plan Free",
          "Sin perfilado cross-site tipo Google",
          "Modos managed/invisible/non-interactive",
          "WCAG 2.2 AAA",
          "No requiere proxy Cloudflare en el sitio",
          "Adecuado para volumen alto de formularios sin costo incremental"
        ],
        "desventajas": [
          "Máx. 20 widgets por cuenta Free; 10 hostnames por widget",
          "Validación server-side requiere secret en backend (Cloud Function)",
          "Ecosistema WordPress menor que reCAPTCHA",
          "Enterprise solo si se necesita >20 widgets o off-label ($$$)"
        ],
        "costoEstimadoMVP": "$0/mes — plan Free suficiente para CariHub MVP (1 sitio, <10 formularios/widgets)",
        "integracionCariHub": "Widget en login/registro/formularios públicos; token → Cloud Function verify; score implícito pass/fail + action binding"
      },
      "google_recaptcha_v3": {
        "ventajas": [
          "Invisible, score 0.0–1.0 continuo",
          "Integración madura con Firebase/App Check (opcional)",
          "Amplio ecosistema y documentación"
        ],
        "desventajas": [
          "Free tier reducido (~10.000 assessments/mes en Cloud 2026)",
          "Costo $8/mes flat 10K–100K; $1/1000 adicional",
          "Dependencia Google / privacidad",
          "Score opaco; umbrales requieren tuning",
          "Migración a reCAPTCHA Enterprise si escala"
        ],
        "costoEstimadoMVP": "$0/mes si <10K verificaciones/mes; riesgo de costo al crecer",
        "integracionCariHub": "grecaptcha.execute → token → Cloud Function siteverify; umbral score ≥0.5 MVP (ajustable)"
      }
    },
    "decision": {
      "proveedor": "cloudflare_turnstile",
      "razon": "Costo cero predecible, privacidad, un solo dominio carihub.app, pocos widgets; CariHub no necesita 20+ widgets distintos",
      "fallback": "recaptcha_v3 solo si Turnstile indisponible en región/dispositivo — documentar en runbook",
      "accionesProtegidasMinimo": ["login", "registro_auth", "registro_perfil", "recuperacion_password", "denuncia", "categoria_sugerida", "contacto_publico", "solicitud_banner"]
    }
  },
  "formulariosProtegidos": {
    "registro_perfiles": {
      "prioridad": "critica",
      "turnstile": true,
      "rateLimit": ["ip", "email", "dispositivo"],
      "emailVerificadoRequerido": "antes_enviar_revision",
      "nota": "Wizard FieldEngine + Firebase Auth signup"
    },
    "registro_anunciantes": {
      "prioridad": "critica",
      "turnstile": true,
      "rateLimit": ["ip", "usuario", "email"],
      "roles": "anunciante sin perfil público posible",
      "nota": "solicitudes_anuncios + contratos_banners"
    },
    "categorias_sugeridas": {
      "prioridad": "alta",
      "turnstile": true,
      "rateLimit": ["ip", "usuario", "email"],
      "maxPorUsuarioDia": 3,
      "nota": "solicitudes_categorias — anti-flood catálogo"
    },
    "denuncias": {
      "prioridad": "alta",
      "turnstile": true,
      "rateLimit": ["ip", "usuario"],
      "maxPorUsuarioDia": 10,
      "maxPorPerfilObjetivoDia": 3,
      "nota": "Permitir anónimo con Turnstile + IP estricto"
    },
    "contacto": {
      "prioridad": "media",
      "turnstile": true,
      "rateLimit": ["ip", "email"],
      "maxPorIpHora": 5,
      "nota": "Formulario soporte público; sin Auth opcional"
    },
    "recuperacion_password": {
      "prioridad": "critica",
      "turnstile": true,
      "rateLimit": ["ip", "email"],
      "maxPorEmailHora": 3,
      "nota": "Firebase sendPasswordResetEmail + Turnstile previo"
    },
    "login": {
      "prioridad": "critica",
      "turnstile": true,
      "rateLimit": ["ip", "email", "dispositivo"],
      "maxIntentosFallidos": 5,
      "ventanaBloqueoMinutos": 15,
      "nota": "Tras N fallos → Turnstile obligatorio + backoff"
    },
    "publicaciones_futuras": {
      "prioridad": "alta",
      "turnstile": false,
      "rateLimit": ["usuario", "perfil"],
      "gates": ["estadoSeguridad", "emailVerificado", "estadoVerificacion", "estadoRevision"],
      "nota": "Usuario autenticado; anti-spam por reputación y límites de edición"
    }
  },
  "antiSpam": {
    "dimensiones": ["ip", "usuario", "email", "telefono", "dispositivo"],
    "almacenamientoLimites": {
      "coleccion": "rate_limits/{bucketId}",
      "bucketId": "hash(tipo+valor+accion+ventana)",
      "ttl": "ventana + margen",
      "nota": "Diseño Firestore con TTL o Cloud Function cleanup — no implementar aún"
    },
    "limitesPorAccion": {
      "registro_cuenta": {
        "ip": { "ventana": "1h", "max": 5 },
        "email": { "ventana": "24h", "max": 3 },
        "dispositivo": { "ventana": "24h", "max": 3 }
      },
      "login_fallido": {
        "ip": { "ventana": "15m", "max": 20 },
        "email": { "ventana": "15m", "max": 5 },
        "dispositivo": { "ventana": "15m", "max": 10 }
      },
      "recuperacion_password": {
        "ip": { "ventana": "1h", "max": 10 },
        "email": { "ventana": "1h", "max": 3 }
      },
      "denuncia": {
        "ip": { "ventana": "24h", "max": 15 },
        "usuario": { "ventana": "24h", "max": 10 },
        "perfilObjetivo": { "ventana": "24h", "max": 5 }
      },
      "categoria_sugerida": {
        "usuario": { "ventana": "24h", "max": 3 },
        "ip": { "ventana": "24h", "max": 10 }
      },
      "mensaje_futuro": {
        "usuario": { "ventana": "1h", "max": 60 },
        "usuario_nuevo": { "ventana": "24h", "max": 20, "condicion": "nivelConfianza < 40" },
        "conversacion": { "ventana": "1m", "max": 10 }
      },
      "publicacion_edicion": {
        "usuario": { "ventana": "1h", "max": 30 },
        "perfil": { "ventana": "24h", "max": 10, "tipo": "cambios_estado_revision" }
      }
    }
  },
  "identidadUsuarioExtension": {
    "subobjeto": "usuarios.seguridad",
    "camposExistentes": ["riesgoScore", "duplicadoPotencial", "ultimoLogin", "ultimoIPHash", "flags"],
    "camposNuevosCongelados": {
      "estadoSeguridad": "normal|observacion|restringido|suspendido|bloqueado",
      "reputacionCuenta": "number 0-100 — confianza agregada post-MVP comportamiento",
      "nivelConfianza": "number 0-100 — usado para límites dinámicos Messenger",
      "emailVerificado": "boolean — mirror Auth emailVerified",
      "fechaVerificacionEmail": "timestamp|null",
      "telefonoVerificado": "boolean",
      "fechaVerificacionTelefono": "timestamp|null",
      "telefonoE164": "string|null — hash o truncado en logs",
      "dispositivoConfianza": "number 0-100 — último device fingerprint score",
      "spamScore": "number 0-100 — acumulado eventos spam",
      "ultimoTurnstileAt": "timestamp",
      "intentosLoginFallidos": "number",
      "bloqueoHasta": "timestamp|null"
    },
    "subobjetoVerificacionEmail": {
      "ubicacion": "usuarios.cuenta o usuarios.verificacion",
      "emailVerificado": "boolean",
      "fechaVerificacionEmail": "timestamp",
      "reenviosRestantes": "number",
      "ultimoReenvioAt": "timestamp",
      "expiracionEnlaceHoras": 24
    }
  },
  "riesgoReputacion": {
    "riesgoScore": {
      "rango": "0-100",
      "inicial": 10,
      "umbrales": {
        "bajo": "0-29",
        "medio": "30-59",
        "alto": "60-79",
        "critico": "80-100"
      },
      "incrementos": [
        { "evento": "login_fallido", "delta": 2, "capHora": 10 },
        { "evento": "rate_limit_excedido", "delta": 15 },
        { "evento": "denuncia_recibida_valida", "delta": 20 },
        { "evento": "denuncia_recibida_rechazada", "delta": 0 },
        { "evento": "duplicado_potencial_detectado", "delta": 25 },
        { "evento": "turnstile_fallido", "delta": 10 },
        { "evento": "email_no_verificado_7d", "delta": 5 }
      ],
      "decrementos": [
        { "evento": "email_verificado", "delta": -10 },
        { "evento": "verificacion_identidad_aprobada", "delta": -20 },
        { "evento": "contrato_activo_30d", "delta": -15 },
        { "evento": "sin_incidentes_90d", "delta": -10 }
      ]
    },
    "reputacionCuenta": {
      "rango": "0-100",
      "inicial": 50,
      "uso": "Visibilidad suave, prioridad revisión admin, elegibilidad promociones",
      "ejemplos": [
        "Cuenta nueva email verificado, sin perfil: reputacion 55",
        "Perfil publicado 6 meses sin denuncias: reputacion 75",
        "3 denuncias válidas en 30d: reputacion 25"
      ]
    },
    "nivelConfianza": {
      "rango": "0-100",
      "formula": "min(100, reputacionCuenta + bonusVerificacion - riesgoScore)",
      "bonusVerificacion": { "email": 10, "telefono": 15, "ine_aprobada": 20, "cedula_aprobada": 25, "rfc_negocio": 20 },
      "usoLimites": "Messenger y categorías sugeridas usan nivelConfianza para caps dinámicos"
    },
    "duplicadoPotencial": {
      "senales": ["mismoIPHash_registros_24h", "mismoDeviceId", "email_similar", "telefono_similar", "ine_hash_duplicado"],
      "accion": "flag + estadoSeguridad observacion + cola admin"
    },
    "flags": {
      "valoresEjemplo": [
        "EMAIL_NO_VERIFICADO",
        "TELEFONO_NO_VERIFICADO",
        "DUPLICADO_SOSPECHOSO",
        "RATE_LIMIT_HIT",
        "DENUNCIA_PENDIENTE",
        "BOT_SOSPECHOSO",
        "PAIS_ALTO_RIESGO",
        "DISPOSITIVO_NUEVO"
      ]
    }
  },
  "mensajeriaFutura": {
    "estadoMensajeria": {
      "habilitada": "envío y recepción normal si nivelConfianza ≥ 40",
      "restringida": "solo respuesta a conversaciones existentes; no iniciar nuevas",
      "suspendida": "sin envío; lectura opcional",
      "solo_lectura": "recibir y leer; no enviar"
    },
    "spamScore": {
      "campo": "usuarios.mensajeria.spamScore",
      "incremento": ["mensajes_identicos", "urls_masivas", "reportes_usuarios", "rate_limit_mensajes"],
      "umbralRestringir": 60,
      "umbralSuspender": 80
    },
    "bloqueos": {
      "ruta": "usuarios/{usuarioId}/bloqueos/{usuarioBloqueadoId}",
      "efecto": "no mensajes bidireccionales"
    },
    "reportes": {
      "incrementa": "mensajeria.reportesCount y riesgoScore",
      "umbralRevision": 3
    },
    "limitesMensajes": {
      "nuevo_usuario_24h": 20,
      "estandar_hora": 60,
      "burst_minuto": 10,
      "adjuntos": "fase_post_mvp"
    }
  },
  "logsAuditoria": {
    "logsAdmin": {
      "ruta": "logsAdmin/{logId}",
      "eventos": ["perfil_aprobar", "perfil_rechazar", "categoria_aprobar", "precio_cambiar", "cuenta_suspendir"],
      "campos": ["actorId", "modulo", "accion", "targetId", "diffHash", "ipHash", "uaHash", "createdAt"],
      "retencionDias": 365
    },
    "logsSeguridad": {
      "ruta": "logsSeguridad/{logId}",
      "eventos": [
        "login_exitoso", "login_fallido", "rate_limit", "turnstile_fallido",
        "estado_seguridad_cambio", "email_verificado", "telefono_verificado",
        "duplicado_detectado", "admin_acceso_privado"
      ],
      "campos": ["tipo", "usuarioId|null", "ipHash", "deviceIdHash", "metadata", "severidad", "createdAt"],
      "retencionDias": 180,
      "pii": "prohibido en claro — solo hash"
    },
    "logs_acceso_privado": {
      "ruta": "logs_acceso_privado/{id}",
      "eventos": ["admin_vio_ine", "admin_vio_telefono", "admin_exporto_datos"],
      "campos": ["adminId", "usuarioId", "campo", "motivo", "createdAt"],
      "retencionDias": 730
    },
    "alertas_seguridad": {
      "ruta": "alertas_seguridad/{id}",
      "disparadores": [
        "riesgoScore >= 80",
        "intentos_login_masivos_ip",
        "oleada_denuncias",
        "cambio_masivo_estados",
        "rules_bypass_intento"
      ],
      "severidad": ["info", "warning", "critical"],
      "destino": "admin modulo seguridad + email super_admin"
    }
  },
