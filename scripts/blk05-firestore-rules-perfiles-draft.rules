// BLK-05-R1 — perfiles/{perfilId} rules (EMULATOR / DRAFT — NO PRODUCTION DEPLOY)
// Contract: scripts/BLK-05-R0-PERFILES-RULES-CONTRACT-FREEZE.md
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Phase 1 helpers ────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isNonAnonymous() {
      return isAuthenticated()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isLegacyAdmin() {
      return isAuthenticated()
        && request.auth.token.email == 'carinosas.anuncios@gmail.com';
    }

    function hasAdminClaim() {
      return isAuthenticated() && (
        (('role' in request.auth.token) && (request.auth.token.role == 'admin' || request.auth.token.role == 'super_admin'))
        || (('roles' in request.auth.token) && request.auth.token.roles.hasAny(['admin', 'super_admin']))
      );
    }

    function isPhase1Admin() {
      return isLegacyAdmin() || hasAdminClaim();
    }

    function perfilForbiddenFieldNames() {
      return [
        'verificacion', 'ine', 'ineFrente', 'ineReverso', 'selfie', 'selfieVerificacion',
        'documentos', 'documentosPrivados', 'documentosInternos', 'curp', 'rfc', 'fiscal',
        'datosFiscales', 'cuentaBancaria', 'clabe', 'payment', 'pagos', 'contratos',
        'renovaciones', 'vencimientos', 'adeudos', 'comprobantes', 'referenciasPago',
        'facturacion', 'datosBancarios', 'tokens', 'secrets', 'token', 'refreshToken',
        'apiKey', 'password', 'perfilesDetalle', 'perfilesVinculados',
        'nombreReal', 'fechaNacimiento', 'domicilio', 'correoPrivado', 'telefonoPrivado',
        'kyc', 'notasAdmin', 'email', 'estadoPago', 'pagado', 'primerMesGratis',
        'auditoria', 'decisionAdmin', 'revisadoPor', 'metadatosRevision'
      ];
    }

    function perfilForbiddenFieldsAbsentOnResource() {
      return !resource.data.keys().hasAny(perfilForbiddenFieldNames());
    }

    function perfilForbiddenFieldsAbsentOnCreate() {
      return !request.resource.data.keys().hasAny(perfilForbiddenFieldNames());
    }

    function fechaVencimientoVigente() {
      return !('fechaVencimiento' in resource.data)
        || resource.data.fechaVencimiento == null
        || resource.data.fechaVencimiento > request.time;
    }

    function estadoPublicacionEsPublicoCanonico() {
      return resource.data.estadoPublicacion == 'publicado'
        || resource.data.estadoPublicacion == 'activo';
    }

    function isPerfilPublico() {
      return perfilForbiddenFieldsAbsentOnResource()
        && resource.data.suspendido != true
        && resource.data.eliminado != true
        && resource.data.vencido != true
        && fechaVencimientoVigente()
        && resource.data.visible == true
        && resource.data.publicado == true
        && resource.data.tienePerfilPublico == true
        && estadoPublicacionEsPublicoCanonico();
    }

    function hubDoc(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data;
    }

    function bridgeOwnerNested(hub, perfilId) {
      return hub != null
        && ('perfil' in hub)
        && hub.perfil is map
        && (
          hub.perfil.perfilPrincipalId == perfilId
          || (('perfilIds' in hub.perfil) && hub.perfil.perfilIds is list && perfilId in hub.perfil.perfilIds)
        );
    }

    function bridgeOwnerFlat(hub, perfilId) {
      return hub != null
        && ('perfilesDetalle' in hub)
        && hub.perfilesDetalle is map
        && perfilId in hub.perfilesDetalle;
    }

    function bridgeOwnerValido(perfilId) {
      let hub = hubDoc(request.auth.uid);
      return bridgeOwnerNested(hub, perfilId) || bridgeOwnerFlat(hub, perfilId);
    }

    function isDirectPerfilOwner() {
      return isAuthenticated()
        && ('ownerUid' in resource.data)
        && ('usuarioId' in resource.data)
        && resource.data.ownerUid == request.auth.uid
        && resource.data.usuarioId == request.auth.uid;
    }

    function isPerfilOwner(perfilId) {
      return isDirectPerfilOwner() || bridgeOwnerValido(perfilId);
    }

    function perfilIdentityImmutable() {
      return request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.usuarioId == resource.data.usuarioId
        && request.resource.data.perfilId == resource.data.perfilId;
    }

    function ownerPublicFieldNames() {
      return [
        'alias', 'slug', 'categoria', 'ciudad', 'estado', 'pais',
        'descripcionPublica', 'fotoPrincipalPublica', 'fotosPublicas',
        'serviciosPublicos', 'horario', 'zona', 'modalidad',
        'precioPublico', 'contactosPublicos', 'nombre', 'descripcion', 'fotos', 'geo',
        'updatedAt'
      ];
    }

    function perfilOwnerUpdateValido() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(ownerPublicFieldNames())
        && request.resource.data.estadoPublicacion == resource.data.estadoPublicacion
        && request.resource.data.visible == resource.data.visible
        && request.resource.data.publicado == resource.data.publicado
        && request.resource.data.tienePerfilPublico == resource.data.tienePerfilPublico
        && request.resource.data.suspendido == resource.data.suspendido
        && request.resource.data.eliminado == resource.data.eliminado
        && request.resource.data.vencido == resource.data.vencido;
    }

    function perfilCreateValido(perfilId) {
      return isNonAnonymous()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.usuarioId == request.auth.uid
        && request.resource.data.perfilId == perfilId
        && request.resource.data.estadoPublicacion in ['borrador', 'pendiente']
        && request.resource.data.visible == false
        && request.resource.data.publicado == false
        && request.resource.data.tienePerfilPublico == false
        && request.resource.data.suspendido == false
        && request.resource.data.eliminado == false
        && request.resource.data.vencido == false
        && perfilForbiddenFieldsAbsentOnCreate();
    }

    function normalizeEstado(estado) {
      return estado == 'activo' ? 'publicado' : estado;
    }

    function validEstadoTransition(de, a) {
      let from = normalizeEstado(de);
      let to = normalizeEstado(a);
      return (from == 'borrador' && to == 'pendiente')
        || (from == 'pendiente' && to == 'borrador')
        || (from == 'pendiente' && to == 'publicado')
        || (from == 'publicado' && to == 'suspendido')
        || (from == 'suspendido' && to == 'publicado')
        || (from == 'vencido' && to == 'publicado')
        || (from != 'eliminado' && to == 'eliminado')
        || (from == to);
    }

    function adminTransitionTargetsPublicado(de, a) {
      let from = normalizeEstado(de);
      let to = normalizeEstado(a);
      return to == 'publicado' && from != 'publicado';
    }

    function adminTransitionTargetsSuspendido(de, a) {
      let from = normalizeEstado(de);
      let to = normalizeEstado(a);
      return to == 'suspendido' && from != 'suspendido';
    }

    // BLK-05 W1 — atomic public visibility bundle (mirror: blk05-perfiles-contract.mjs)
    function perfilAdminPublishBundleValido() {
      return request.resource.data.estadoPublicacion == 'publicado'
        && request.resource.data.visible == true
        && request.resource.data.publicado == true
        && request.resource.data.tienePerfilPublico == true
        && request.resource.data.suspendido == false
        && request.resource.data.vencido == false;
    }

    function perfilAdminSuspendBundleValido() {
      return request.resource.data.estadoPublicacion == 'suspendido'
        && request.resource.data.visible == false
        && request.resource.data.publicado == false
        && request.resource.data.tienePerfilPublico == false
        && request.resource.data.suspendido == true;
    }

    function perfilAdminUpdateValido() {
      let de = resource.data.estadoPublicacion;
      let a = request.resource.data.estadoPublicacion;
      return validEstadoTransition(de, a)
        && ('revisadoPor' in request.resource.data)
        && request.resource.data.revisadoPor == request.auth.uid
        && ('decisionAdmin' in request.resource.data)
        && perfilIdentityImmutable()
        && (!adminTransitionTargetsPublicado(de, a) || perfilAdminPublishBundleValido())
        && (!adminTransitionTargetsSuspendido(de, a) || perfilAdminSuspendBundleValido());
    }

    function ownerEstadoTransitionValido() {
      let de = resource.data.estadoPublicacion;
      let a = request.resource.data.estadoPublicacion;
      return (de == 'borrador' && a == 'pendiente')
        || (de == 'pendiente' && a == 'borrador');
    }

    function perfilOwnerEstadoUpdateValido() {
      return ownerEstadoTransitionValido()
        && perfilIdentityImmutable()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estadoPublicacion', 'updatedAt']);
    }

    // Minimal usuarios read for bridge tests (production rules unchanged in candidate merge)
    match /usuarios/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false;
    }

    match /perfiles/{perfilId} {

      allow read: if isPerfilPublico()
        || isPerfilOwner(perfilId)
        || isPhase1Admin();

      allow create: if perfilCreateValido(perfilId);

      allow update: if perfilIdentityImmutable() && (
        (isPerfilOwner(perfilId) && (perfilOwnerUpdateValido() || perfilOwnerEstadoUpdateValido()))
        || (isPhase1Admin() && perfilAdminUpdateValido())
      );

      allow delete: if false;
    }

    match /pagos/{pagoId} {
      allow read: if isAuthenticated() && resource.data.usuarioId == request.auth.uid;
      allow write: if false;
    }

    match /contratos_perfiles/{contratoId} {
      allow read: if isAuthenticated() && resource.data.usuarioId == request.auth.uid;
      allow write: if false;
    }

    match /contratos_banners/{contratoBannerId} {
      allow read: if isAuthenticated() && resource.data.anuncianteId == request.auth.uid;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
