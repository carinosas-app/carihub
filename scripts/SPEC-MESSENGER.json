    { "id": "OB-MSG-5", "nota": "admin_automatizaciones_suspendir en catálogo VE" },
    { "id": "OB-MSG-6", "nota": "algoritmo conversacionId + política duplicados" },
    { "id": "OB-MSG-7", "nota": "ANEXO integración Dashboards sin modificar acta" },
    { "id": "OB-MSG-8", "nota": "telefonoVerificado gate + spamScore canónico + VE MINOR" }
