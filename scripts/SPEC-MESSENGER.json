      "participanteMayorId": "max(usuarioIdA, usuarioIdB)",
      "politicaDuplicados": {
        "regla": "Una conversación canónica por trío (usuarioA, usuarioB, perfilContextoId)",
        "mismoParDistintoPerfil": "conversacionId distinto — bandejas separadas por contexto perfil",
        "mismoParMismoPerfil": "reutilizar conversacionId existente si estado ≠ cerrada_admin",
        "reaperturaTrasRechazo": "nueva solicitud reutiliza mismo conversacionId si solicitud_rechazada; cooldown 24h AM recomendado"
      },
      "nota": "OB-MSG-6 — ids determinísticos evitan duplicados Firestore"
    },
    "conversacionesMeta": {
      "ruta": "usuarios/{usuarioId}/conversaciones_meta/{conversacionId}",
