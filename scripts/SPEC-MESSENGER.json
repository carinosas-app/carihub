      "fase": "FASE_7_POST_MESSENGER",
      "nota": "Messenger base; conversaciones desde estados no expiran con estado"
    }
  },
  "proposito": "Especificar CariHub Messenger como módulo/aplicación independiente: conversaciones internas, seguridad, moderación, automatizaciones, control admin granular e integración con capas congeladas vía ValidationEngine.",
  "principios": [
    "Messenger es app separada — no embebida en index/resultados/perfil",
    "Toda persistencia pasa validateAction — ValidationEngine 1.0.0",
    "Visitante sin cuenta no envía mensajes",
    "Email y teléfono verificados obligatorios para enviar",
    "No exponer teléfono privado en UI Messenger",
    "IA y automatizaciones nunca envían sin autorización explícita del dueño",
    "Sanciones finales: reglas sistema + moderación admin",
    "No modificar capas congeladas — cambios VE solo vía acta MINOR documentada"
  ],
  "arquitectura": {
    "modelo": "aplicacion_modulo_independiente",
    "plataforma": "CariHub",
    "componente": "CariHub Messenger",
    "puntoEntrada": "Botón «Mensaje interno» en perfil público → /messenger",
    "separacion": "Firestore colecciones messenger propias; reglas seguridad propias (diseño); panel admin módulo mensajería",
    "moduloCentral": true,
    "nivelPlataforma": ["usuarios", "perfiles", "banners", "administracion", "pagos", "messenger"],
    "diagrama": "perfil.html → validateAction(conversacion_iniciar|mensaje_enviar) → Messenger UI → EventBus → notificaciones/historial"
  },
  "rutas": {
    "base": "/messenger",
    "rutas": [
      { "path": "/messenger", "vista": "bandeja_conversaciones", "auth": "requerida" },
      { "path": "/messenger/chat/:conversacionId", "vista": "chat", "auth": "requerida" },
      { "path": "/messenger/configuracion", "vista": "config_usuario_automatizaciones", "auth": "requerida" },
      { "path": "/messenger/reportes", "vista": "mis_reportes", "auth": "requerida" },
      { "path": "/messenger/solicitudes", "vista": "solicitudes_pendientes", "auth": "requerida" }
    ],
    "admin": [
      { "path": "/admin/mensajeria", "vista": "cola_reportes_y_controles", "rol": "admin" },
      { "path": "/admin/mensajeria/conversacion/:id", "vista": "revision_denunciada", "rol": "admin" },
      { "path": "/admin/mensajeria/controles", "vista": "control_granular_global", "rol": "admin" }
    ],
    "legacyHtml": ["messenger.html", "chat.html"]
  },
