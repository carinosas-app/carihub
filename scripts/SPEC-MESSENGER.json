        "mensajesNoLeidos": "number",
        "ordenFijada": "number|null — 1..5"
      },
      "nota": "OB-MSG-2 — única fuente para archivar|silenciar|fijar|ocultar; conversación global no almacena estas flags"
    },
    "conversacion": {
      "campos": {
        "conversacionId": "string — ver algoritmo conversacionId",
        "participante1Id": "usuarioId — menor lexicográfico",
        "participante2Id": "usuarioId — mayor lexicográfico",
        "participantesSnapshot": "ParticipanteSnapshot[] — solo alias/foto/tipo; sin configLocal",
        "perfilContextoId": "perfilId — perfil desde el que se inició",
        "sectorId": "string|null",
        "subcategoriaId": "string|null",
        "fechaCreacion": "timestamp",
        "ultimoMensaje": "string preview sanitizado",
        "fechaUltimoMensaje": "timestamp",
        "estadoConversacion": "EstadoConversacion",
        "solicitudPendiente": "boolean",
        "solicitudDeUsuarioId": "usuarioId|null",
        "bloqueada": "boolean",
        "bloqueadaPor": "usuarioId|admin|null",
        "reportada": "boolean",
        "enInvestigacion": "boolean",
        "investigacionDesde": "timestamp|null",
        "cerradaAdmin": "boolean",
        "motivoCierreAdmin": "string|null",
        "etiquetas": "string[]",
        "metadataInteracciones": "object|null — liveId, estadoId futuro Fase 7"
      }
    },
    "participanteSnapshot": {
      "usuarioId": "string",
      "perfilId": "string|null",
      "aliasVisible": "string",
      "fotoPerfilUrl": "string|null",
      "tipoCuenta": "string",
      "rolesCuenta": "string[]",
      "nota": "Denormalizado; refresh en lectura bandeja; preferencias en conversaciones_meta"
    },
    "mensaje": {
      "campos": {
        "mensajeId": "string",
        "conversacionId": "string",
        "emisorId": "usuarioId",
        "receptorId": "usuarioId",
        "texto": "string",
        "textoSanitizado": "string",
        "mensajeOriginal": "string|null — traducción",
        "mensajeTraducido": "string|null",
        "idiomaOrigen": "string|null",
        "idiomaDestino": "string|null",
        "createdAt": "timestamp",
        "estadoEntrega": "enviado|entregado|visto",
        "tipo": "texto|imagen|audio|archivo|ubicacion|sistema|automatizado|asistente_ia",
        "adjunto": "AdjuntoRef|null",
        "origenMensaje": "humano|automatizacion|asistente_ia",
        "reglaAutomatizacionId": "string|null",
        "asistenteId": "string|null",
        "marcadoAutomatizado": "boolean — obligatorio si origen ≠ humano",
        "senalRiesgoId": "string|null",
        "eliminadoParaTodos": "boolean",
        "eliminadoAt": "timestamp|null",
        "eliminadoPor": "usuarioId|null",
        "preservadoInvestigacion": "boolean",
        "editadoAt": "timestamp|null"
      }
