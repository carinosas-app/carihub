  "matrices": {
    "agenteResponsabilidades": "Ver inventarioAgentes[].objetivo/responsabilidades por agente",
    "agentePermisos": {
      "soloLectura(L0/L1)": ["ia_home", "ia_resultados", "ia_perfil_publico", "ia_wizard", "ia_dash_*", "ia_admin_general", "ia_seguridad", "ia_cumplimiento", "ia_contratos", "ia_messenger", "ia_recuperacion_cuenta", "ia_analitica", "ia_antifraude", "ia_recomendaciones"],
      "borradorStaging(L2)": ["ia_seo", "ia_landing", "ia_registro_*", "ia_verificacion", "ia_moderacion", "ia_pagos", "ia_banners", "ia_admin_seo", "ia_soporte_*", "ia_facturacion", "ia_marketing", "ia_optimizacion_seo", "ia_themeengine"],
      "ejecucion(L3)": "NINGUNO por defecto — solo vía motor autorizado con aprobación humana puntual y AuditTrail"
    },
    "agenteModulosAccesibles": {
      "ia_home/resultados/perfil_publico": ["AppPublica(lectura)", "Catálogo público", "RenderEngine(salida)"],
      "ia_registro_*/wizard/verificacion": ["Registro/Cuenta", "FieldEngine", "ValidationEngine"],
      "ia_dash_*": ["Dashboards(lectura del dueño)"],
      "ia_admin_*/moderacion/seguridad/auditoria/cumplimiento": ["Admin(lectura + borrador)", "logs"],
      "ia_pagos/contratos/facturacion": ["Pagos/Contratos(lectura + borrador conciliación)"],
      "ia_banners/seo/landing": ["Banners/SEO(lectura + borrador)", "RenderEngine"],
      "ia_messenger": ["Messenger(metadatos; contenido solo con denuncia+auditoría)"]
    },
    "agenteDatosAccesibles": {
      "publicos": ["catálogo", "geo", "perfiles publicados", "métricas públicas"],
      "porDuenio": ["ia_dash_* → métricas del dueño"],
      "sensiblesConPrivacyGuard": ["ia_verificacion → INE/selfie", "ia_facturacion → RFC", "ia_messenger → conversación solo en denuncia"],
      "prohibidos": ["cualquier agente → datos de terceros sin propósito", "logs inmutables (escritura)", "credenciales"]
    },
    "agenteAprobacionHumana": {
      "noRequiere(soloInforma)": ["ia_home", "ia_resultados", "ia_perfil_publico", "ia_wizard", "ia_dash_*(lectura)"],
      "requiereAprobacion(publicar/aplicar)": ["ia_seo", "ia_landing", "ia_registro_*", "ia_verificacion", "ia_moderacion", "ia_pagos", "ia_banners", "ia_admin_seo", "ia_soporte_*", "ia_facturacion", "ia_themeengine"],
      "dobleConfirmacion(RT-08)": ["ia_pagos(reembolso/confirmación)", "ia_moderacion(suspender/eliminar)", "ia_recuperacion_cuenta(reset)"]
    },
    "agenteRiesgo": {
      "alto": ["ia_verificacion(privacidad INE)", "ia_pagos(financiero/legal)", "ia_moderacion(legal)", "ia_messenger(privacidad)", "ia_cumplimiento(legal)", "ia_facturacion(fiscal)", "ia_recuperacion_cuenta(seguridad)"],
      "medio": ["ia_seo", "ia_landing", "ia_banners", "ia_seguridad", "ia_auditoria"],
      "bajo": ["ia_home", "ia_resultados", "ia_wizard", "ia_dash_*", "ia_traduccion"]
    }
  },

  "cicloVidaAgente": "diseño → registro en AgentRegistry(permisos/scope/nivel) → pruebas en sandbox(golden) → habilitación por Admin(feature flag) → operación(L0..L2 con AuditTrail) → monitoreo(rate-limit/anomalías) → revisión periódica → deprecación/rollback",
  "cicloVidaInteraccionIA": "trigger(evento/usuario) → cargar contexto(need-to-know + PrivacyGuard) → razonamiento → salida tipada(recomendacion|borrador|alerta) → AuditTrail(origen=agente) → si requiere acción: a cola de aprobación humana → humano decide → motor ejecuta → log resultado → feedback/explicabilidad",

  "politicas": {
    "seguridad": ["deny-write por defecto", "scope por rol+propósito", "service accounts restringidas", "circuit-breaker", "sin acceso a credenciales/logs inmutables", "Turnstile/reputación (Seguridad MVP) condiciona agentes públicos"],
    "privacidad": ["PrivacyGuard en prompts y salidas", "need-to-know", "no PII en logs en claro (hashes)", "acceso a sensibles (INE/RFC/conversaciones) con propósito + log obligatorio", "no entrenar con datos privados sin base legal"],
    "auditoria": ["toda acción de agente en AuditTrail(origen=agente, modelo, prompt-hash, entrada, salida, decisión humana)", "logs append-only", "informes de IA marcados recomendacion_no_accion"],
    "trazabilidad": ["correlación evento→agente→salida→decisión→ejecución", "origen humano|sistema|agente en cada evento", "versionado de prompts/modelos"],
    "explicabilidad": ["citar fuentes/datos usados", "anclar a índices (no alucinar entidades)", "exponer confianza/limitaciones", "lenguaje claro para usuario; detalle técnico para Admin/auditor"]
  },

  "integraciones": {
    "sharedCore": "config/helpers/clientes; AgentRegistry como cliente, no motor",
    "renderEngine": "agentes públicos producen contenido vía snapshot; PrivacyGuard obligatorio",
    "validationEngine": "valida borradores/transiciones generados por agentes",
    "fieldEngine": "agentes de registro/wizard resuelven campos",
    "registroCuenta": "identidad/edad/estado condiciona agentes",
    "dashboards": "agentes de dashboard solo leen lo del dueño",
    "admin": "AgentRegistry, feature flags, cola de aprobación, RBAC (PLAN-MAESTRO-ADMIN)",
    "messenger": "metadatos/antispam; contenido solo en denuncia con auditoría",
    "pagos": "conciliación asistida; nunca confirma/reembolsa",
    "contratos": "auditoría de congelados/vencimientos; no modifica activos",
    "banners": "recomendación de precio/ocupación; nunca auto-publica",
    "interacciones": "recomendación/feed; nunca genera interacciones reales (IX-R09)",
    "seo": "borradores de metadatos/landings; aprobación humana",
    "themeEngine": "sugiere temas; no aplica sin aprobación",
    "seguridadMvp": "gates/reputación condicionan ejecución de agentes"
  },

  "riesgos": [
    { "id": "AI-R01", "nivel": "critico", "riesgo": "Agente con permisos de escritura ejecuta acción irreversible", "mitigacion": "RT-01/RT-06/RT-08 + deny-write por defecto + L3 inexistente por defecto" },
    { "id": "AI-R02", "nivel": "critico", "riesgo": "Fuga de datos sensibles (INE/RFC/conversaciones) en prompts/salidas", "mitigacion": "PrivacyGuard + need-to-know + log de acceso (RT-05)" },
    { "id": "AI-R03", "nivel": "alto", "riesgo": "Moderación/decisión automática sin humano", "mitigacion": "RT-07 + cola de aprobación + Admin decide" },
    { "id": "AI-R04", "nivel": "alto", "riesgo": "Alucinación sobre categorías/entidades inexistentes", "mitigacion": "anclar a índices + explicabilidad (RT-12)" },
    { "id": "AI-R05", "nivel": "alto", "riesgo": "Agente infla métricas o genera interacciones falsas", "mitigacion": "IA solo recomienda; origen=agente nunca cuenta (Interacciones RT-04)" },
    { "id": "AI-R06", "nivel": "medio", "riesgo": "Costos/abuso (loops, prompt injection)", "mitigacion": "rate-limit, presupuesto, circuit-breaker, sanitización (RT-11)" },
    { "id": "AI-R07", "nivel": "medio", "riesgo": "Confusión entre recomendación y ejecución", "mitigacion": "salida tipada (RT-03) + UI clara" },
    { "id": "AI-R08", "nivel": "medio", "riesgo": "Agente visible al usuario expone info interna", "mitigacion": "separación visible/interno (RT-09) + PrivacyGuard" },
    { "id": "AI-R09", "nivel": "medio", "riesgo": "Falta de trazabilidad de decisiones IA", "mitigacion": "AuditTrail completo + versionado de prompts/modelos (RT-02)" },
    { "id": "AI-R10", "nivel": "bajo", "riesgo": "Dependencia de proveedor de modelo", "mitigacion": "abstracción de proveedor + fallback" }
  ],
  "dependencias": {
    "congeladas": ["Shared/Core 1.0.0", "RenderEngine 1.0.0", "ValidationEngine 1.1.0", "FieldEngine 1.0.1", "Messenger 1.0.0", "Seguridad MVP 1.0.0", "Dashboards 1.0.0"],
    "planes": ["ADMIN", "REGISTRO-CUENTA", "PAGOS-CONTRATOS", "BANNERS", "INTERACCIONES", "APP-PUBLICA"],
    "precondiciones": ["AgentRegistry + RBAC de agentes", "AuditTrail operativo", "PrivacyGuard", "cola de aprobación humana", "sandbox + golden fixtures por agente"]
  },
  "estructuraIdealFutura": {
