// BLK-01 Phase 1C-b — EMULATOR TEST ONLY. NOT FOR PRODUCTION DEPLOY.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /perfiles/{perfilId} {
      allow read: if true;
      allow write: if false;
    }
    match /usuarios/{uid} {
      allow read: if true;
      allow write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
