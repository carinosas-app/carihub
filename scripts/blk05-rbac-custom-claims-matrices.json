  "claimSchema": {
    "estrategia": "Custom claim 'role' (string unico) preferido para MVP; 'roles' (array) reservado para multi-rol futuro. hasRole/hasAnyRole en rules ya soportan ambos.",
    "limiteBytes": 1000,
    "campos": {
      "role": "string — rol unico de plataforma (super_admin|admin|moderador|soporte|auditor|agente_ia|sistema)",
      "roles": "string[] — OPCIONAL multi-rol futuro; evitar en MVP",
      "claimsVersion": "number — version del esquema de claims para invalidar tokens viejos",
      "assignedBy": "string(uid) — quien asigno (solo super_admin para roles criticos)",
      "assignedAt": "number(epoch ms) — emision",
      "expiresAt": "number(epoch ms)|null — elevacion temporal (seccion 30)",
      "scopeRegion": "string|null — futuro multi-pais/regional (no MVP)",
      "scopeOrg": "string|null — futuro multi-empresa/franquicia (no MVP)",
      "mfa": "boolean — 2FA verificado en la sesion (futuro)",
      "deviceTrust": "number 0-100 — confianza de dispositivo (futuro)"
    },
    "noDebeContener": [
      "PII (email, telefono, nombre)",
      "secretos / tokens de pago",
      "datos que cambian con frecuencia (riesgoScore, estadoSeguridad)",
      "permisos granulares por documento (eso vive en rules + datos)"
    ],
    "fuenteDeVerdad": "El claim es fuente de verdad del ROL en rules. usuarios/{uid}.roles es espejo legible para UI/auditoria, NUNCA autoritativo para seguridad.",
    "sincronizacion": "Cloud Function setea claim Y escribe usuarios.roles + logsAdmin. Divergencia claim<->doc = alerta_seguridad."
  },

  "jerarquiaHerencia": {
    "modelo": "Herencia parcial declarada en rules (no transitiva libre).",
    "reglas": [
      "isAdmin() = super_admin OR admin",
      "isModerator() = moderador OR isAdmin()",
      "isSupport() = soporte OR isAdmin()",
      "isAuditor() = auditor OR isAdmin()",
      "super_admin NO hereda auditor (SoD: auditor debe ser observador puro; ver seccion 28/33)",
      "sistema NO hereda nada humano; es servicio",
      "agente_ia NO hereda lectura privada/financiera"
    ],
    "advertenciaSoD": "La inclusion de isAdmin() dentro de isAuditor() es comodidad operativa MVP, pero ROMPE separacion de privilegios para auditoria independiente. Ver seccion 28: en post-MVP el auditor debe ser claim exclusivo sin herencia admin."
  },

