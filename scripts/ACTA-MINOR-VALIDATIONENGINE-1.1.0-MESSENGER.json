  "requisitosAuditoriaIncorporados": {
    "REQ-01": {
      "id": "REQ-01",
      "titulo": "Transformación plantilla fanout → fanOutPlan[] canónico",
      "estado": "INCORPORADO",
      "algoritmoTransformacion": {
        "descripcion": "Al aplicar acta, cada entrada de registry-messenger-fanout-propuesta se convierte a fanOutPlan[] según OB-VE2",
        "reglas": [
          "Si historial.emitir === true → fanOutPlan.push({ destino: 'historial', dominio, tipoEvento, destinatario: 'usuarioId' | dinámico })",
          "Si notificacion.emitir === true → por cada item en notificacion.items → fanOutPlan.push({ destino: 'notificacion', dominio, tipoEvento, destinatario })",
          "Si logsSeguridad.emitir === true | condicional_* → registrar en entrada registry logsSeguridad; no duplicar en fanOutPlan salvo diseño explícito",
          "Si iaRecomendaciones.emitir condicional → metadata fanOutPlan o side-channel ia_recomendaciones según patrón enviar_revision",
          "Si logsAdmin.emitir → side-channel logsAdmin",
          "Eliminar dependencia de placeholders emitir:false en mensaje_enviar y conversacion_iniciar legacy"
        ],
        "ejemploMensajeEnviar": {
          "accion": "mensaje_enviar",
          "fanOutPlan": [
            { "destino": "historial", "dominio": "historial_mensajes", "tipoEvento": "mensaje_enviado", "destinatario": "usuarioId" },
            { "destino": "notificacion", "dominio": "mensajes", "tipoEvento": "mensaje_nuevo", "destinatario": "receptorId_dinamico" }
          ],
          "logsSeguridad": { "emitir": "condicional_spam", "tipo": "mensaje_enviado" },
          "iaRecomendaciones": { "emitir": "condicional_senal_riesgo", "estadoNuevo": "sugerida" }
        }
      },
      "archivoAplicacion": "scripts/registry-validationengine-eventos.json"
    },
    "REQ-02": {
      "id": "REQ-02",
      "titulo": "Eliminación conversacion_iniciar y routing modoInicio",
      "estado": "INCORPORADO",
      "eliminarRegistry": ["conversacion_iniciar"],
      "routing": {
        "entradaCliente": "conversacion_iniciar",
        "metadata": "metadata.modoInicio",
        "resolucion": {
          "directa": "conversacion_iniciar_directa",
          "solicitud": "conversacion_iniciar_solicitud"
        },
        "pasoPipeline": "Antes de paso 12 fanOutPlan — normalizar accion en validateAction",
        "fuente": "registry-messenger-fanout-propuesta.json → mapeoConversacionIniciar"
